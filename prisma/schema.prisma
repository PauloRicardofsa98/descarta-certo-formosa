generator client {
  provider = "prisma-client"
  output   = "../app/_generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  ACTIVE
  INACTIVE
}

enum ReportStatus {
  PENDING
  APPROVED
  RESOLVED
  REJECTED
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admins")
}

model WasteType {
  id                      String   @id @default(cuid())
  name                    String   @unique
  slug                    String   @unique
  description             String?
  preparationInstructions String?
  synonyms                String?
  icon                    String?
  order                   Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  disposalPoints DisposalPointWasteType[]

  @@map("waste_types")
}

model DisposalPoint {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  address     String
  latitude    Float?
  longitude   Float?
  photos      String[] @default([])
  hours       Json
  phone       String?
  description String?
  website     String?
  status      Status   @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wasteTypes DisposalPointWasteType[]

  @@index([status])
  @@map("disposal_points")
}

model DisposalPointWasteType {
  disposalPointId String
  wasteTypeId     String

  disposalPoint DisposalPoint @relation(fields: [disposalPointId], references: [id], onDelete: Cascade)
  wasteType     WasteType     @relation(fields: [wasteTypeId], references: [id], onDelete: Cascade)

  @@id([disposalPointId, wasteTypeId])
  @@index([wasteTypeId])
  @@map("disposal_point_waste_types")
}

model PageView {
  id          String   @id @default(cuid())
  path        String
  wasteTypeId String?
  pointId     String?

  sessionHash String
  ipHash      String
  userAgent   String?
  isBot       Boolean  @default(false)

  referrer  String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([wasteTypeId])
  @@index([pointId])
  @@index([isBot, createdAt])
  @@map("page_views")
}

model SearchEvent {
  id           String   @id @default(cuid())
  term         String
  resultsCount Int
  sessionHash  String
  ipHash       String
  isBot        Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([term])
  @@index([isBot, createdAt])
  @@map("search_events")
}

model IrregularDisposalReport {
  id             String       @id @default(cuid())
  protocol       String       @unique
  description    String
  photos         String[]     @default([])
  latitude       Float
  longitude      Float
  referencePoint String?
  status         ReportStatus @default(PENDING)
  adminNotes     String?

  sessionHash String
  ipHash      String

  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@map("irregular_disposal_reports")
}
